{% stylesheet %}
  .product-page-timberland {
    --timberland-media-bg: #f3f3f3;
    --timberland-muted: rgb(var(--color-foreground-rgb) / 0.55);
    --timberland-page-gutter: clamp(1rem, 3vw, 3rem);
  }

  .product-page-timberland__breadcrumbs {
    width: 100%;
    max-width: var(--page-width);
    margin-inline: auto;
    padding-inline: var(--timberland-page-gutter);
    margin-block-end: var(--padding-md);
  }

  .product-page-timberland .product-breadcrumbs__list {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.35rem;
    margin: 0;
    padding: 0;
    list-style: none;
    font-size: 0.8125rem;
    color: var(--timberland-muted);
  }

  .product-page-timberland .product-breadcrumbs__item {
    display: inline-flex;
    align-items: center;
  }

  .product-page-timberland .product-breadcrumbs__item:not(:last-child)::after {
    content: '/';
    margin-inline-start: 0.35rem;
    color: var(--timberland-muted);
  }

  .product-page-timberland .product-breadcrumbs__link {
    color: inherit;
    text-decoration: none;
  }

  .product-page-timberland .product-breadcrumbs__link:hover {
    color: var(--color-foreground);
    text-decoration: underline;
  }

  .product-page-timberland .product-breadcrumbs__item--current span {
    color: var(--color-foreground);
  }

  /* 50/50 product grid */
  .product-page-timberland .product-information__grid {
    display: grid;
    grid-column: 1 / -1;
    width: 100%;
    max-width: none;
    gap: 0;
    align-items: start;
  }

  .product-page-timberland .product-information__media {
    width: 100%;
    min-width: 0;
    padding: 0;
    margin: 0;
    background: var(--timberland-media-bg);
  }

  .product-page-timberland .product-information__media .product-media-container,
  .product-page-timberland .product-information__media .slideshow,
  .product-page-timberland .product-information__media .product-media,
  .product-page-timberland .product-information__media .media-gallery {
    width: 100%;
    background: var(--timberland-media-bg);
  }

  .product-page-timberland .product-information__media .product-media-container {
    border-radius: 12px;
    overflow: hidden;
  }

  .product-page-timberland .product-information__media img,
  .product-page-timberland .product-information__media video {
    width: 100%;
    height: auto;
    object-fit: contain;
  }

  .product-page-timberland .product-details {
    padding: 0;
    margin: 0;
    width: 100%;
    min-width: 0;
    align-self: start;
  }

  .product-page-timberland .product-details > .group-block {
    padding-inline: var(--timberland-page-gutter);
    padding-block: var(--padding-lg);
    width: 100%;
    max-width: none;
  }

  @media screen and (min-width: 750px) {
    .product-page-timberland .product-information__grid:not(.product-information--media-none) {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      gap: clamp(1.5rem, 3vw, 3rem);
    }

    .product-page-timberland .product-information--media-left .product-information__media {
      grid-column: 1;
      grid-row: 1;
    }

    .product-page-timberland .product-information--media-left .product-details {
      grid-column: 2;
      grid-row: 1;
    }

    .product-page-timberland .product-information--media-right .product-information__media {
      grid-column: 2;
      grid-row: 1;
    }

    .product-page-timberland .product-information--media-right .product-details {
      grid-column: 1;
      grid-row: 1;
    }

    .product-page-timberland .product-details > .group-block {
      padding-block: clamp(1rem, 2vw, 2rem);
      padding-inline-start: clamp(0.5rem, 2vw, 2rem);
      padding-inline-end: var(--timberland-page-gutter);
    }

    .product-page-timberland .product-information--media-left .product-information__media .product-media-container {
      min-height: min(70vh, 640px);
    }
  }

  @media screen and (max-width: 749px) {
    .product-page-timberland .product-information__grid {
      grid-template-columns: 1fr;
    }

    .product-page-timberland .product-information__media,
    .product-page-timberland .product-details {
      grid-column: 1 / -1;
    }

    .product-page-timberland .product-details > .group-block {
      padding-block: var(--padding-lg);
    }
  }

  /* Block order: vendor → title → reviews → price → description → features → variants → buy */
  .product-page-timberland .product-details .group-block-content {
    display: flex;
    flex-direction: column;
    align-items: stretch;
  }

  .product-page-timberland .product-details .group-block-content > .view-product-title {
    display: none;
  }

  .product-page-timberland .timberland-injected-vendor {
    order: 10;
  }

  .product-page-timberland .product-details .group-block-content > .text-block:has(h1) {
    order: 20;
  }

  .product-page-timberland .timberland-injected-rating,
  .product-page-timberland .product-details .rating-wrapper {
    order: 30;
  }

  .product-page-timberland .timberland-injected-rating:has(~ .rating-wrapper) {
    display: none;
  }

  .product-page-timberland .product-details product-price {
    order: 40;
    display: block;
    margin-block: var(--padding-sm) var(--padding-md);
    font-size: clamp(1.25rem, 2vw, 1.5rem);
    font-weight: var(--font-weight-semibold);
  }

  .product-page-timberland .product-details product-price .price {
    font-size: inherit;
    font-weight: inherit;
    margin: 0;
  }

  .product-page-timberland .product-details .timberland-product-description,
  .product-page-timberland .product-details [class*='product_description'] {
    order: 50;
    margin-block: 0 var(--padding-md);
    font-size: 0.9375rem;
    line-height: 1.6;
    color: rgb(var(--color-foreground-rgb) / 0.85);
  }

  .product-page-timberland .timberland-injected-features {
    order: 60;
    margin-block: var(--padding-lg);
  }

  .product-page-timberland .product-details variant-picker {
    order: 70;
  }

  .product-page-timberland .product-details .buy-buttons-block {
    order: 80;
  }

  .product-page-timberland .product-vendor {
    margin: 0 0 var(--padding-xs);
    font-size: 0.875rem;
    font-weight: var(--font-weight-regular);
    color: var(--timberland-muted);
    letter-spacing: 0.01em;
  }

  .product-page-timberland .product-details .text-block h1 {
    font-size: clamp(1.75rem, 2.5vw, 2.25rem);
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin: 0;
  }

  .product-page-timberland .product-rating-placeholder {
    display: flex;
    align-items: center;
    gap: var(--gap-xs);
    margin: var(--padding-sm) 0 var(--padding-md);
    font-size: 0.8125rem;
    color: var(--timberland-muted);
  }

  .product-page-timberland .product-rating-placeholder__stars {
    letter-spacing: 0.15em;
    color: rgb(var(--color-foreground-rgb) / 0.25);
  }

  .product-page-timberland .timberland-injected-features .product-main-features__list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--padding-xl);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .product-page-timberland .timberland-injected-features .product-main-features__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--padding-sm);
    min-width: 5.5rem;
    text-align: center;
    font-size: 0.75rem;
    color: var(--timberland-muted);
  }

  .product-page-timberland .timberland-injected-features .timberland-feature-icon {
    width: 1.5rem;
    height: 1.5rem;
  }

  .product-page-timberland .product-main-features__title {
    margin: 0 0 var(--padding-md);
    font-size: 0.9375rem;
    font-weight: var(--font-weight-semibold);
  }

  .product-page-timberland .variant-option--buttons legend {
    font-size: 0.9375rem;
    font-weight: var(--font-weight-semibold);
    margin-block-end: var(--padding-sm);
    color: var(--color-foreground);
  }

  .product-page-timberland .variant-option__swatch-value {
    display: none;
  }

  .product-page-timberland .variant-option--swatches {
    gap: var(--padding-md);
  }

  .product-page-timberland .variant-option--swatches .variant-option__button-label {
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    gap: var(--padding-xs);
    min-width: 4.5rem;
    min-height: auto;
    padding: 0;
    border: none;
    border-radius: 0;
    background: transparent;
    overflow: visible;
  }

  .product-page-timberland .variant-option--swatches .variant-option__button-label .swatch {
    --variant-picker-swatch-width: 3.75rem;
    --variant-picker-swatch-height: 3.75rem;
    width: var(--variant-picker-swatch-width);
    height: var(--variant-picker-swatch-height);
    border-radius: 6px;
    border: 1px solid rgb(var(--color-foreground-rgb) / 0.12);
  }

  .product-page-timberland .variant-option--swatches .variant-option__button-label:has(:checked) .swatch {
    outline: 2px solid var(--color-foreground);
    outline-offset: 1px;
  }

  .product-page-timberland .variant-option__swatch-label {
    font-size: 0.75rem;
    color: var(--timberland-muted);
    text-align: center;
    line-height: 1.2;
    white-space: nowrap;
  }

  .product-page-timberland .variant-option--circles {
    gap: var(--padding-sm);
  }

  .product-page-timberland .variant-option--circles .variant-option__button-label {
    --options-border-radius: 50%;
    width: 3rem;
    height: 3rem;
    min-width: 3rem;
    min-height: 3rem;
    flex: 0 0 3rem;
    padding: 0;
    border-color: rgb(var(--color-foreground-rgb) / 0.2);
    background: transparent;
  }

  .product-page-timberland .variant-option--circles .variant-option__button-label:has(:checked) {
    border-color: var(--color-foreground);
    border-width: 2px;
    background: transparent;
  }

  .product-page-timberland .variant-option--circles .variant-option__button-label:has([data-option-available='false']) {
    opacity: 0.35;
    text-decoration: line-through;
  }

  .product-page-timberland .variant-option--circles .variant-option__button-label__text {
    font-size: 0.8125rem;
  }

  .product-page-timberland .variant-option--circles .variant-option__button-label__pill {
    display: none;
  }

  .product-page-timberland .variant-option--pills {
    gap: var(--padding-sm);
  }

  .product-page-timberland .variant-option--pills .variant-option__button-label {
    --options-border-radius: 999px;
    width: auto;
    height: auto;
    min-width: 5.5rem;
    min-height: 2.75rem;
    flex: 0 0 auto;
    padding-inline: 1.5rem;
    border-color: rgb(var(--color-foreground-rgb) / 0.2);
    background: transparent;
    border-radius: 999px;
  }

  .product-page-timberland .variant-option--pills .variant-option__button-label:has(:checked) {
    border-color: var(--color-foreground);
    border-width: 2px;
    background: transparent;
  }

  .product-page-timberland .variant-option--pills .variant-option__button-label__text {
    font-size: 0.875rem;
  }

  .product-page-timberland .variant-option--pills .variant-option__button-label__pill {
    display: none;
  }

  .product-page-timberland .product-details .buy-buttons-block {
    margin-block-start: var(--padding-lg);
    padding-block-start: var(--padding-lg);
    border-top: 1px solid rgb(var(--color-foreground-rgb) / 0.12);
  }

  .product-page-timberland .product-form-buttons {
    align-items: center;
    flex-wrap: wrap;
    gap: var(--padding-sm);
  }

  .product-page-timberland .product-form-buttons .quantity-selector-wrapper {
    flex: 0 0 auto;
  }

  .product-page-timberland .product-form-buttons .quantity-selector {
    border: 1px solid rgb(var(--color-foreground-rgb) / 0.15);
    border-radius: 999px;
    padding-inline: var(--padding-xs);
  }

  .product-page-timberland .product-form-buttons .add-to-cart-button.button {
    background-color: #000;
    color: #fff;
    border-radius: 999px;
    flex: 1 1 8rem;
    min-height: 3rem;
    text-transform: none;
    font-weight: var(--font-weight-medium);
    box-shadow: none;
  }

  .product-page-timberland .product-form-buttons .add-to-cart-button.button:hover {
    background-color: #222;
    color: #fff;
  }

  .product-page-timberland .product-form-buttons .accelerated-checkout-block {
    flex: 1 1 8rem;
    min-width: fit-content;
  }

  .product-page-timberland .product-form-buttons .shopify-payment-button {
    width: 100%;
  }

  .product-page-timberland .product-form-buttons button.shopify-payment-button__button--unbranded {
    background-color: transparent;
    color: var(--color-foreground);
    border-radius: 999px;
    min-height: 3rem;
    text-transform: none;
    font-weight: var(--font-weight-medium);
    box-shadow: inset 0 0 0 1px var(--color-foreground);
  }

  .product-page-timberland .product-form-buttons button.shopify-payment-button__button--unbranded:hover:not([disabled]) {
    background-color: rgb(var(--color-foreground-rgb) / 0.04);
    color: var(--color-foreground);
  }

  .timberland-recommendations .section {
    --timberland-page-gutter: clamp(1rem, 3vw, 3rem);
  }

  .timberland-recommendations .section-resource-list__header,
  .timberland-recommendations .section-resource-list__content {
    padding-inline: var(--timberland-page-gutter);
  }

  .timberland-recommendations .resource-list {
    padding-inline: var(--timberland-page-gutter);
  }

  .timberland-recommendations .section-resource-list__content .text-block p {
    font-size: clamp(1.125rem, 2vw, 1.375rem);
    font-weight: var(--font-weight-semibold);
    margin: 0;
    text-align: left;
  }
{% endstylesheet %}
