{% stylesheet %}
  .product-card--timberland {
    --timberland-card-bg: #f3f3f3;
    --timberland-card-gutter: 1rem;
    --timberland-card-radius: 12px;
    height: 100%;
  }

  .product-card--timberland .product-card__content {
    background: var(--timberland-card-bg);
    border-radius: var(--timberland-card-radius);
    overflow: hidden;
    padding: 0;
    gap: 0;
    height: 100%;
  }

  .product-card--timberland .product-card__content > *:first-child,
  .product-card--timberland .product-card__content > .product-card-gallery,
  .product-card--timberland .product-card__content > [class*='product-card-gallery'] {
    background: var(--timberland-card-bg);
  }

  .product-card--timberland .product-card__content > *:not(:first-child) {
    padding-inline: var(--timberland-card-gutter);
  }

  .product-card--timberland .product-card__content > *:last-child {
    padding-block-end: var(--timberland-card-gutter);
  }

  .product-card--timberland product-price,
  .product-card--timberland .price {
    padding-block-start: var(--timberland-card-gutter);
    font-size: 0.9375rem;
    font-weight: var(--font-weight-semibold);
    margin: 0;
  }

  .product-card--timberland .product-title,
  .product-card--timberland [class*='product-title'],
  .product-card--timberland .text-block h3,
  .product-card--timberland .text-block p:not(.product-rating-placeholder) {
    font-size: 0.875rem;
    line-height: 1.35;
    margin: 0;
  }

  .product-card--timberland .product-rating-placeholder {
    display: flex;
    align-items: center;
    gap: var(--gap-xs);
    margin: 0.35rem 0;
    font-size: 0.75rem;
    color: rgb(var(--color-foreground-rgb) / 0.55);
  }

  .product-card--timberland .product-rating-placeholder__stars {
    letter-spacing: 0.12em;
    color: rgb(var(--color-foreground-rgb) / 0.25);
  }

  .product-card--timberland .timberland-card-buy {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 2.5rem;
    margin-block: 0.5rem 0.35rem;
    border-radius: 999px;
    text-decoration: none;
    text-transform: none;
    font-size: 0.875rem;
    font-weight: var(--font-weight-medium);
  }

  .product-card--timberland .product-card__content .group-block:has(.icon-block) {
    display: flex;
    flex-direction: row;
    gap: 0.5rem;
    padding-block-end: var(--timberland-card-gutter);
    opacity: 0.7;
  }

  .product-card--timberland .product-card__content .group-block:has(.icon-block) .icon-block__media {
    width: 1rem;
    height: 1rem;
  }

  .product-card--timberland .product-card__content .rating-wrapper {
    padding-inline: var(--timberland-card-gutter);
    font-size: 0.75rem;
  }
{% endstylesheet %}
